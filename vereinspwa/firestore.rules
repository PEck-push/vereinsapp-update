rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // adminUsers doc ID IS the uid (set at admin creation)
    function isAdminOfClub(clubId) {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/clubs/$(clubId)/adminUsers/$(request.auth.uid));
    }

    // FIXED: Player docs use Firestore-generated IDs (not uids).
    // playerUids/{uid} is a mapping doc written by Admin SDK in /api/auth/set-claims.
    function isPlayerOfClub(clubId) {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/clubs/$(clubId)/playerUids/$(request.auth.uid));
    }

    function isOwnPlayerDoc() {
      return isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // NEW: Check if an event is still accepting responses
    function isEventOpen(clubId, eventId) {
      return get(/databases/$(database)/documents/clubs/$(clubId)/events/$(eventId)).data.status == 'scheduled';
    }

    match /clubs/{clubId} {
      allow read: if isAdminOfClub(clubId) || isPlayerOfClub(clubId);
      allow create: if false;
      allow update, delete: if isAdminOfClub(clubId);

      // playerUids: mapping from Firebase Auth UID → playerId.
      // Written exclusively by Admin SDK (set-claims route). No client writes allowed.
      match /playerUids/{uid} {
        allow read: if isSignedIn() && request.auth.uid == uid;
        allow write: if false; // Admin SDK only
      }

      // SECURITY FIX: adminUsers read restricted to club-scoped admins only.
      // Previously any admin could read all other admins across clubs.
      // Now only admins of THIS club can read/write admin user documents.
      match /adminUsers/{uid} {
        allow read, write: if isAdminOfClub(clubId);
      }

      match /teams/{teamId} {
        allow read: if isAdminOfClub(clubId) || isPlayerOfClub(clubId);
        allow write: if isAdminOfClub(clubId);
      }

      // Players: admins have full access, players can read their own doc
      // and update specific profile fields (phone, photo, FCM tokens, notification prefs).
      match /players/{playerId} {
        allow read, write: if isAdminOfClub(clubId);
        allow read: if isOwnPlayerDoc();
        allow update: if isOwnPlayerDoc() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['phone', 'photoUrl', 'fcmTokens', 'notificationPrefs', 'updatedAt']);
      }

      match /events/{eventId} {
        allow read: if isAdminOfClub(clubId) || isPlayerOfClub(clubId);
        allow create, update, delete: if isAdminOfClub(clubId);

        // Responses: admins can read all, players can only read their own response.
        // Players can create/update their own response only when the event is still 'scheduled'.
        match /responses/{responsePlayerId} {
          allow read: if isAdminOfClub(clubId);
          allow read: if isSignedIn() &&
            get(/databases/$(database)/documents/clubs/$(clubId)/playerUids/$(request.auth.uid)).data.playerId == responsePlayerId;

          // FIX: Only allow responses on events that are still 'scheduled' (not cancelled/completed)
          allow create, update: if isSignedIn() &&
            isEventOpen(clubId, eventId) &&
            get(/databases/$(database)/documents/clubs/$(clubId)/playerUids/$(request.auth.uid)).data.playerId == responsePlayerId &&
            request.resource.data.keys().hasOnly(['playerId','status','reason','declineCategory','respondedAt','source']) &&
            request.resource.data.status in ['accepted', 'declined'] &&
            request.resource.data.playerId == responsePlayerId;
          allow delete: if isAdminOfClub(clubId);
        }

        // Event reminders: tracks last reminder sent per player (rate-limiting).
        // Written by Admin SDK only (notifications/remind API route).
        match /reminders/{playerId} {
          allow read: if isAdminOfClub(clubId);
          allow write: if false; // Admin SDK only
        }
      }

      // SECURITY FIX: matchStats restricted to club members only.
      // Previously readable by any signed-in user.
      // Now only admins and players of THIS club can read match statistics.
      match /matchStats/{statId} {
        allow read: if isAdminOfClub(clubId) || isPlayerOfClub(clubId);
        allow write: if isAdminOfClub(clubId);
      }

      // SECURITY FIX: messages collection — admin-only read/write.
      // Previously had no security rules (unprotected).
      // Now only admins of THIS club can read and write messages.
      match /messages/{messageId} {
        allow read, write: if isAdminOfClub(clubId);
      }

      // Mail collection: used by Firebase "Trigger Email from Firestore" extension.
      // Written by Admin SDK only when generating invite emails.
      match /mail/{mailId} {
        allow read: if isAdminOfClub(clubId);
        allow write: if false; // Admin SDK only
      }

      // Audit log: tracks critical admin actions (player deletion, event cancellation, etc.).
      // Read-only for admins/secretaries; written exclusively by Admin SDK.
      match /auditLog/{logId} {
        allow read: if isAdminOfClub(clubId);
        allow write: if false; // Admin SDK only
      }

      // Analytics: aggregated metrics (notification opt-in rates, etc.).
      // Written by Admin SDK, readable by admins.
      match /analytics/{docId} {
        allow read: if isAdminOfClub(clubId);
        allow write: if false; // Admin SDK only
      }
    }
  }
}
